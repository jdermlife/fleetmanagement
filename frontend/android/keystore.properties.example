# Copy this file to `keystore.properties` in `frontend/android/` and fill real values.
# Do not commit `keystore.properties` or the `.jks` / `.keystore` file.
# `storeFile` may be a filename in `frontend/android/` or a full absolute path.

storeFile=release-keystore.jks
storePassword=replace_with_strong_password
keyAlias=release_key_alias
keyPassword=replace_with_strong_password
