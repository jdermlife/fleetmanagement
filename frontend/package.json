    "@neondatabase/serverless": "^1.1.0",
    "axios": "^1.16.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
