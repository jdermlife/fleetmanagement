# Neon PostgreSQL Connection (fleet_mgmt_db database)
# Get your connection string from https://console.neon.tech
# Format: postgresql://[user]:[password]@[host]/fleet_mgmt_db
DATABASE_URL=postgresql://user:password@ec2-xx-xxx-xxx-xxx.compute-1.amazonaws.com/fleet_mgmt_db

# Frontend API URL
VITE_API_URL=http://localhost:5000
