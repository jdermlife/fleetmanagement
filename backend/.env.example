# Backend Database Configuration
# 
# PostgreSQL Connection (REQUIRED - no SQLite fallback)
# Get your Neon PostgreSQL connection string from https://console.neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/your_database?sslmode=require

# Optional: Flask Environment
# FLASK_ENV=production
# FLASK_DEBUG=0

