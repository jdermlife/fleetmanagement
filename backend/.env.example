# Backend environment template
# Copy to backend/.env and replace placeholder values.

ENVIRONMENT=production

# Database
DATABASE_URL=postgresql://username:password@db-host:5432/fms?sslmode=require
AUTO_RUN_SCHEMA_MIGRATIONS=false

# Authentication
ENFORCE_AUTH=true
SECRET_KEY=replace-with-strong-64-hex-or-random-string
TOKEN_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30
GOOGLE_OAUTH_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# CORS
FRONTEND_ORIGINS=https://fleetmanagement.vercel.app,https://fleetmanagement-flame.vercel.app
FRONTEND_ORIGIN_REGEX=^https://fleetmanagement(?:-[a-z0-9-]+)?(?:-jdionedas-projects)?\.vercel\.app$

# Rate limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://redis-host:6379/0
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# API docs
ENABLE_API_DOCS=false

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

# Notifications
NOTIFICATION_DISPATCHER_ENABLED=true
NOTIFICATION_DISPATCH_INTERVAL_SECONDS=30
NOTIFICATION_DISPATCH_BATCH_SIZE=100
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BASE_SECONDS=60
